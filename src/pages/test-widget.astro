<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Test Widget</title>
    <script is:inline>
      console.log('=== Widget Test Page ===');
      window.PoltekkesChat = {
        apiBase: 'https://element-welcome-hash-kathy.trycloudflare.com',
        autoOpen: false
      };
      console.log('Config set:', window.PoltekkesChat);
    </script>
  </head>
  <body style="margin: 0; padding: 20px; font-family: Arial, sans-serif; background: #f5f5f5;">
    <h1>Widget Test Page</h1>
    <p>Bubble should appear at bottom-right corner</p>
    <p style="color: #666;">Check browser console (F12) for debug messages</p>

    <script is:inline src="https://element-welcome-hash-kathy.trycloudflare.com/widget.js" async></script>

    <script is:inline>
      // Wait for widget to load
      setTimeout(() => {
        console.log('Widget loaded check');
        console.log('Window keys:', Object.keys(window).filter(k => k.includes('Chat') || k.includes('pk') || k.includes('cw')));
        const wrap = document.querySelector('.cw-wrap');
        console.log('cw-wrap found:', !!wrap);
      }, 2000);
    </script>
  </body>
</html>
