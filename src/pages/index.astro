---
import Header from '../components/Header.astro';
import HeroSlider from '../components/HeroSlider.astro';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Poltekkes Yogyakarta - Website Resmi" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>Poltekkes Yogyakarta - Website Resmi</title>
  </head>
  <body class="bg-white">
    <Header />
    <main>
      <HeroSlider />
    </main>

    <script is:inline>
      // Set config IMMEDIATELY
      window.PoltekkesChat = {
        apiBase: 'https://element-welcome-hash-kathy.trycloudflare.com',
        autoOpen: false
      };

      // Ensure widget loads AFTER body is ready
      function loadWidget() {
        if (!document.body) {
          setTimeout(loadWidget, 10);
          return;
        }

        const script = document.createElement('script');
        script.src = 'https://element-welcome-hash-kathy.trycloudflare.com/widget.js';
        script.async = true;
        script.onload = function() {
          console.log('✓ Widget loaded successfully');
          setTimeout(function() {
            console.log('✓ Launcher visible:', !!document.querySelector('.cw-launcher'));
          }, 200);
        };
        script.onerror = function() {
          console.error('✗ Failed to load widget');
        };
        document.body.appendChild(script);
      }

      // Load when DOM is ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', loadWidget);
      } else {
        loadWidget();
      }
    </script>
  </body>
</html>

