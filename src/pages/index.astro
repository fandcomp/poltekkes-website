---
import Header from '../components/Header.astro';
import HeroSlider from '../components/HeroSlider.astro';
import '../styles/global.css';
---

<style>
  .chatbot-container {
    position: fixed;
    bottom: 0;
    right: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2147483647;
  }

  .chatbot-container iframe {
    position: fixed;
    bottom: 0;
    right: 0;
    width: 100%;
    height: 100%;
    border: none;
    pointer-events: auto;
  }
</style>

<div class="chatbot-container">
  <iframe src="https://hobby-dresses-resort-miami.trycloudflare.com/demo.html" title="VirtualAssist Chatbot"></iframe>
</div>

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Poltekkes Yogyakarta - Website Resmi" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>Poltekkes Yogyakarta - Website Resmi</title>
  </head>
  <body class="bg-white">
    <Header />
    <main>
      <HeroSlider />
    </main>
  </body>
</html>

