---
import Header from '../components/Header.astro';
import HeroSlider from '../components/HeroSlider.astro';
import '../styles/global.css';
---

<style>
  .chatbot-widget {
    position: fixed;
    bottom: 20px;
    right: 20px;
    width: 380px;
    height: 600px;
    border: none;
    border-radius: 8px;
    box-shadow: 0 5px 40px rgba(0, 0, 0, 0.16);
    z-index: 2147483647;
  }
</style>

<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Poltekkes Yogyakarta - Website Resmi" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>Poltekkes Yogyakarta - Website Resmi</title>
  </head>
  <body class="bg-white">
    <Header />
    <main>
      <HeroSlider />
    </main>
    <iframe class="chatbot-widget" src="https://hobby-dresses-resort-miami.trycloudflare.com/demo.html" title="VirtualAssist Chatbot"></iframe>
  </body>
</html>

