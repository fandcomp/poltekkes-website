---
interface Props {
  label: string;
  items: string[];
  isActive?: boolean;
}

const { label, items, isActive = false } = Astro.props;
---

<div class="relative group">
  <button
    class={`
      flex items-center gap-1 text-menu font-medium transition-colors duration-200 relative
      ${isActive ? 'text-accent' : 'text-gray-800'}
      hover:text-accent focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-white
    `}
    aria-expanded="false"
    aria-haspopup="true"
    id={`dropdown-${label.toLowerCase()}`}
  >
    <span>{label}</span>
    {isActive && <span class="absolute bottom-0 left-0 right-0 h-0.5 bg-accent"></span>}
    <svg
      class={`w-4 h-4 transition-transform duration-200 ${isActive ? 'text-accent' : 'text-gray-800'}`}
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
  
  <div
    class="
      absolute top-full left-0 mt-2 w-56 bg-white rounded-lg shadow-lg
      opacity-0 invisible group-hover:opacity-100 group-hover:visible
      transition-all duration-[120ms] ease-in-out
      transform translate-y-2 group-hover:translate-y-0
      z-50
    "
    role="menu"
    aria-labelledby={`dropdown-${label.toLowerCase()}`}
  >
    <div class="py-2">
      {items.map((item) => (
        <a
          href={`#${item.toLowerCase().replace(/\s+/g, '-')}`}
          class="
            block px-6 py-3 text-sm text-text-dark font-medium
            hover:bg-gray-50 transition-colors duration-150
            focus:outline-none focus:bg-gray-50
          "
          role="menuitem"
        >
          {item}
        </a>
      ))}
    </div>
  </div>
</div>

