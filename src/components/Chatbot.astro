---
// Widget chatbot VirtualAssist Poltekkes
// Terhubung ke backend publik via Cloudflare Tunnel
---

<script is:inline>
  // Configuration: admin only needs to set `apiBase` (the host where your widget is deployed)
  (function(){
    const stored = localStorage.getItem('poltekkes_chat_apiBase');
    window.PoltekkesChat = {
      apiBase: stored || 'https://hobby-dresses-resort-miami.trycloudflare.com',
      autoOpen: false, // if true, widget will load immediately
      lazyLoad: true // if true, show button and load on click
    };

    // Expose setter for admin: call from console or admin UI
    window.setPoltekkesChatApiBase = function (url, persist = true) {
      try {
        const u = new URL(url);
        window.PoltekkesChat.apiBase = u.origin;
        if (persist) localStorage.setItem('poltekkes_chat_apiBase', u.origin);
        console.info('PoltekkesChat apiBase set to', u.origin);
        return u.origin;
      } catch (e) {
        console.error('Invalid URL passed to setPoltekkesChatApiBase', url, e);
        throw e;
      }
    };

    // Small admin panel when ?poltekkes-admin=1 is present
    if (location.search.indexOf('poltekkes-admin=1') !== -1) {
      const panel = document.createElement('div');
      Object.assign(panel.style, {
        position: 'fixed',
        right: '20px',
        top: '20px',
        background: '#fff',
        border: '1px solid #ddd',
        padding: '10px',
        borderRadius: '6px',
        boxShadow: '0 6px 18px rgba(0,0,0,0.12)',
        zIndex: 2147483647,
        fontSize: '13px'
      });
      panel.innerHTML = `
        <div style="margin-bottom:6px;font-weight:600">Chat Widget Admin</div>
        <input id="poltekkes-admin-input" style="width:260px;padding:6px;border:1px solid #ccc;border-radius:4px" placeholder="https://your-chat-host.example.com" value="${window.PoltekkesChat.apiBase}">
        <div style="margin-top:8px;display:flex;gap:8px">
          <button id="poltekkes-admin-save" style="padding:6px 10px;background:#0b74de;color:#fff;border:none;border-radius:4px;cursor:pointer">Save</button>
          <button id="poltekkes-admin-clear" style="padding:6px 10px;background:#eee;border:none;border-radius:4px;cursor:pointer">Clear</button>
        </div>
      `;
      document.addEventListener('DOMContentLoaded', () => document.body.appendChild(panel));
      document.addEventListener('click', (e) => {
        if (e.target && e.target.id === 'poltekkes-admin-save') {
          const v = document.getElementById('poltekkes-admin-input').value.trim();
          try {
            window.setPoltekkesChatApiBase(v, true);
            alert('Saved apiBase: ' + window.PoltekkesChat.apiBase);
          } catch (e) { alert('Invalid URL'); }
        }
        if (e.target && e.target.id === 'poltekkes-admin-clear') {
          localStorage.removeItem('poltekkes_chat_apiBase');
          alert('Cleared saved apiBase. Reload the page.');
        }
      });
    }
  })();

  (function () {
    function sanitizeBase(raw) {
      try {
        const url = new URL(raw);
        return url.origin; // only keep origin
      } catch (e) {
        return null;
      }
    }

    function ensureRoot() {
      if (!document.getElementById('poltekkes-chat-root')) {
        const root = document.createElement('div');
        root.id = 'poltekkes-chat-root';
        document.body.appendChild(root);
      }
    }

    function createToggleButton() {
      if (document.getElementById('poltekkes-chat-toggle')) return;
      const btn = document.createElement('button');
      btn.id = 'poltekkes-chat-toggle';
      btn.title = 'Open chat';
      btn.setAttribute('aria-label', 'Open chat');
      Object.assign(btn.style, {
        position: 'fixed',
        right: '20px',
        bottom: '20px',
        width: '56px',
        height: '56px',
        borderRadius: '50%',
        border: 'none',
        background: '#0b74de',
        color: '#fff',
        boxShadow: '0 4px 12px rgba(0,0,0,0.15)',
        cursor: 'pointer',
        zIndex: 2147483647,
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        fontSize: '20px'
      });
      btn.innerText = '💬';
      btn.addEventListener('click', onToggleClicked);
      document.body.appendChild(btn);
    }

    let scriptLoaded = false;
    function loadWidgetScript() {
      if (scriptLoaded) return Promise.resolve();
      return new Promise((resolve, reject) => {
        try {
          const raw = window.PoltekkesChat.apiBase;
          const base = sanitizeBase(raw);
          if (!base) return reject(new Error('Invalid apiBase URL'));
          ensureRoot();
          const s = document.createElement('script');
          s.defer = true;
          s.src = base + '/widget/chat-widget.js';
          s.onload = function () {
            scriptLoaded = true;
            console.info('Poltekkes chat-widget.js loaded from', s.src);
            // If widget exposes init function, call it
            try {
              if (window.PoltekkesChat && typeof window.PoltekkesChat.init === 'function') {
                window.PoltekkesChat.init();
                console.info('Called window.PoltekkesChat.init()');
              }
            } catch (e) {
              console.warn('Error while calling PoltekkesChat.init()', e);
            }
            // quick check
            setTimeout(() => {
              const widgetPresent = document.querySelector('#poltekkes-chat-root *') || document.querySelector('.poltekkes-chat') || document.querySelector('.chat-widget');
              if (!widgetPresent) console.warn('Chat widget loaded but no UI elements found.');
            }, 500);
            resolve();
          };
          s.onerror = function (e) {
            console.error('Failed to load poltekkes chat-widget.js from', s.src, e);
            reject(new Error('Failed to load script'));
          };
          document.head.appendChild(s);
        } catch (e) {
          reject(e);
        }
      });
    }

    function onToggleClicked(e) {
      const btn = e.currentTarget;
      btn.disabled = true;
      btn.innerText = '...';
      loadWidgetScript().then(() => {
        btn.style.display = 'none';
      }).catch((err) => {
        console.error(err);
        btn.disabled = false;
        btn.innerText = '💬';
        alert('Gagal memuat chat widget. Periksa Console untuk detail.');
      });
    }

    // Boot: render button or auto-load
    try {
      if (window.PoltekkesChat.autoOpen) {
        loadWidgetScript().catch((e) => console.warn(e));
      } else if (window.PoltekkesChat.lazyLoad) {
        createToggleButton();
      } else {
        // default: lazy load
        createToggleButton();
      }
    } catch (e) {
      console.error('Chatbot integration error', e);
    }
  })();
</script>
