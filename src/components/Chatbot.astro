---
// Widget chatbot VirtualAssist Poltekkes
// Terhubung ke backend publik via Cloudflare Tunnel
---

<script is:inline>
  (function () {
    const chatbotUrl = 'https://hobby-dresses-resort-miami.trycloudflare.com/demo.html';

    function ensureRoot() {
      if (!document.getElementById('poltekkes-chat-root')) {
        const root = document.createElement('div');
        root.id = 'poltekkes-chat-root';
        Object.assign(root.style, {
          position: 'fixed',
          right: '20px',
          bottom: '20px',
          width: '380px',
          height: '600px',
          maxWidth: 'calc(100vw - 40px)',
          maxHeight: '80vh',
          borderRadius: '8px',
          boxShadow: '0 5px 40px rgba(0,0,0,0.16)',
          zIndex: 2147483647,
          backgroundColor: '#fff',
          display: 'none',
          flexDirection: 'column'
        });
        document.body.appendChild(root);
      }
      return document.getElementById('poltekkes-chat-root');
    }

    function createToggleButton() {
      if (document.getElementById('poltekkes-chat-toggle')) return;
      const btn = document.createElement('button');
      btn.id = 'poltekkes-chat-toggle';
      btn.title = 'Buka chat';
      btn.setAttribute('aria-label', 'Buka chat');
      Object.assign(btn.style, {
        position: 'fixed',
        right: '20px',
        bottom: '20px',
        width: '56px',
        height: '56px',
        borderRadius: '50%',
        border: 'none',
        background: '#00796B',
        color: '#fff',
        boxShadow: '0 4px 12px rgba(0,0,0,0.15)',
        cursor: 'pointer',
        zIndex: 2147483646,
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        fontSize: '24px',
        transition: 'transform 0.2s ease'
      });
      btn.innerHTML = '💬';
      btn.addEventListener('click', onToggleClicked);
      btn.addEventListener('mouseenter', () => btn.style.transform = 'scale(1.1)');
      btn.addEventListener('mouseleave', () => btn.style.transform = 'scale(1)');
      document.body.appendChild(btn);
    }

    function onToggleClicked() {
      const root = document.getElementById('poltekkes-chat-root');
      const btn = document.getElementById('poltekkes-chat-toggle');
      const isOpen = root.style.display === 'flex';

      if (isOpen) {
        root.style.display = 'none';
        btn.style.display = 'flex';
      } else {
        root.style.display = 'flex';
        btn.style.display = 'none';
      }
    }

    function loadChatWidget() {
      const root = ensureRoot();

      const iframe = document.createElement('iframe');
      iframe.src = chatbotUrl;
      iframe.style.cssText = `
        border: none;
        width: 100%;
        height: 100%;
        borderRadius: '8px';
      `;
      iframe.allow = 'microphone; camera';
      iframe.title = 'Chat Widget';

      root.appendChild(iframe);
      createToggleButton();
      console.info('Chat widget loaded from', chatbotUrl);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', loadChatWidget);
    } else {
      loadChatWidget();
    }
  })();
</script>
